{
  "commands": [
    {
      "category": "Commit Message Generator",
      "command": "commit-message-generator.generateCommit",
      "title": "%command.generateCommit.title%",
      "icon": {
        "light": "images/logo.svg",
        "dark": "images/logo.svg"
      }
    },
    {
      "category": "Commit Message Generator",
      "command": "commit-message-generator.stopGeneration",
      "title": "%command.stopGeneration.title%",
      "icon": "$(primitive-square)"
    },
    {
      "category": "Commit Message Generator",
      "command": "commit-message-generator.selectAvailableModel",
      "title": "%command.selectAvailableModel.title%"
    },
    {
      "category": "Commit Message Generator",
      "command": "commit-message-generator.showTokenStats",
      "title": "%command.showTokenStats.title%"
    },
    {
      "category": "Commit Message Generator",
      "command": "commit-message-generator.resetTokenStats",
      "title": "%command.resetTokenStats.title%"
    }
  ],
  "configuration": {
    "title": "Commit Message Generator",
    "properties": {
      "commit-message-generator.service.baseURL": {
        "default": "https://api.deepseek.com",
        "markdownDescription": "%configuration.service.baseURL.description%",
        "type": "string",
        "order": 0
      },
      "commit-message-generator.service.apiKey": {
        "default": "",
        "markdownDescription": "%configuration.service.apiKey.description%",
        "type": "string",
        "order": 1
      },
      "commit-message-generator.service.model": {
        "default": "deepseek-chat",
        "markdownDescription": "%configuration.service.model.description%",
        "type": "string",
        "order": 2
      },
      "commit-message-generator.format.outputLanguage": {
        "default": "简体中文",
        "markdownDescription": "%configuration.format.outputLanguage.description%",
        "enum": [
          "简体中文",
          "繁體中文",
          "にほんご",
          "한국어",
          "česky",
          "Deutsch",
          "française",
          "italiano",
          "Nederlands",
          "português",
          "tiếng Việt",
          "English",
          "español",
          "Svenska",
          "русский",
          "bahasa",
          "Polski",
          "Türkçe",
          "ไทย"
        ],
        "type": "string",
        "order": 10
      },
      "commit-message-generator.commit.autoStage": {
        "default": false,
        "markdownDescription": "%configuration.commit.autoStage.description%",
        "type": "boolean",
        "order": 29
      },
      "commit-message-generator.commit.enableEmojiPrefix": {
        "default": false,
        "markdownDescription": "%configuration.commit.enableEmojiPrefix.description%",
        "type": "boolean",
        "order": 30
      },
      "commit-message-generator.commit.customPrompt": {
        "default": "",
        "markdownDescription": "%configuration.commit.customPrompt.description%",
        "type": "string",
        "editPresentation": "multilineText",
        "order": 31
      }
    }
  },
  "menus": {
    "scm/title": [
      {
        "command": "commit-message-generator.generateCommit",
        "group": "navigation",
        "when": "scmProvider === git && !commit-message-generator.isGenerating"
      },
      {
        "command": "commit-message-generator.stopGeneration",
        "group": "navigation",
        "when": "scmProvider === git && commit-message-generator.isGenerating"
      }
    ]
  }
}
